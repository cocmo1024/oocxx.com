---
import HeaderLink from './HeaderLink.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="header-brand">
		<p class="eyebrow">OOCXX / INTERNET ARCHAEOLOGY LAB</p>
		<h1>
			<a class="site-title-link" href="/">{SITE_TITLE}</a>
		</h1>
		<p class="site-summary">{SITE_DESCRIPTION}</p>
	</div>

	<div class="header-meta">
		<nav class="primary-nav" aria-label="Primary">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Archive</HeaderLink>
			<HeaderLink href="/topics">Topics</HeaderLink>
			<HeaderLink href="/about">Lab</HeaderLink>
		</nav>
		<p class="header-note">{SITE_TAGLINE}</p>
	</div>
</header>
