---
interface Props {
	date: Date;
}

const { date } = Astro.props;
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const formattedDate = `${monthNames[date.getUTCMonth()]} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;
---

<time datetime={date.toISOString()}>
	{formattedDate}
</time>
