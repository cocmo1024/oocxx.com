---
interface Props {
	slotId: string;
	format?: "rectangle" | "tower" | "banner" | "inline" | "mobile";
	headline?: string;
	note?: string;
}

const {
	slotId,
	format = "rectangle",
	headline = "Reserved ad placement",
	note = "Swap this placeholder for your ad network script or sponsored creative.",
} = Astro.props;

const formatMap = {
	rectangle: { className: "ad-slot-rectangle", size: "300 x 250" },
	tower: { className: "ad-slot-tower", size: "300 x 600" },
	banner: { className: "ad-slot-banner", size: "728 x 90 / responsive" },
	inline: { className: "ad-slot-inline", size: "Responsive in-article unit" },
	mobile: { className: "ad-slot-mobile mobile-only", size: "320 x 100 / mobile" },
};

const current = formatMap[format];
const hasCustomContent = Astro.slots.has("default");
---

<aside class:list={["ad-slot", current.className]} aria-label={`Advertisement slot ${slotId}`}>
	<div class="ad-slot-label-row">
		<span>Advertisement</span>
		<span>{slotId}</span>
	</div>

	<div class="ad-slot-shell">
		{
			hasCustomContent ? (
				<slot />
			) : (
				<div class="ad-slot-placeholder">
					<p class="ad-slot-title">{headline}</p>
					<p class="ad-slot-size">{current.size}</p>
				</div>
			)
		}
	</div>

	<p class="ad-slot-copy">{note}</p>
</aside>
