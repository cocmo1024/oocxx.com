---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	featured?: boolean;
}

const { post, featured = false } = Astro.props;
const tags = post.data.tags.slice(0, 3);
---

<article class:list={['post-card', { featured }]}>
	<a class="post-card-link" href={`/blog/${post.id}/`}>
		<div class="post-card-media">
			{post.data.heroImage ? (
				<img src={post.data.heroImage} alt="" width={720} height={420} />
			) : (
				<div class="post-card-media"></div>
			)}
		</div>

		<div class="post-card-body">
			<div class="meta-row">
				<span class="meta-pill">{post.data.section}</span>
				<FormattedDate date={post.data.pubDate} />
			</div>
			<h2 class="post-card-title">{post.data.title}</h2>
			<p>{post.data.description}</p>
			{tags.length > 0 && (
				<ul class="tag-row" aria-label="Article topics">
					{tags.map((tag) => (
						<li>{tag}</li>
					))}
				</ul>
			)}
			<p class="section-kicker">Read the full field note</p>
		</div>
	</a>
</article>
