---
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from './ClassicShell.astro';
import { SITE_AUTHOR, SITE_TITLE, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	postId: string;
};

const { title, description, pubDate, updatedDate, heroImage, section, tags, postId } = Astro.props;

const pageURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).toString();
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter((entry) => entry.id !== postId)
	.map((entry) => {
		const sharedTags = entry.data.tags.filter((tag) => tags.includes(tag)).length;
		const sameSection = entry.data.section === section ? 2 : 0;
		return { entry, score: sharedTags * 3 + sameSection };
	})
	.filter(({ score }) => score > 0)
	.sort((a, b) => b.score - a.score || b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf())
	.slice(0, 3)
	.map(({ entry }) => entry);

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	image: heroImage ? [new URL(heroImage, Astro.site ?? SITE_URL).toString()] : undefined,
	author: {
		'@type': 'Organization',
		name: SITE_AUTHOR,
		url: SITE_URL,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
	},
	mainEntityOfPage: pageURL,
	keywords: tags.join(', '),
	articleSection: section,
};
---

<ClassicShell
	title={`${title} | ${SITE_TITLE}`}
	description={description}
	image={heroImage}
	showPageIntro={false}
	ogType="article"
	publishedTime={pubDate.toISOString()}
	modifiedTime={(updatedDate ?? pubDate).toISOString()}
	schema={articleSchema}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Entry Data" eyebrow="Artifact File">
			<p><strong>Section:</strong> {section}</p>
			<p><strong>Published:</strong> <FormattedDate date={pubDate} /></p>
			{updatedDate && <p><strong>Updated:</strong> <FormattedDate date={updatedDate} /></p>}
			{tags.length > 0 && (
				<ul>
					{tags.map((tag) => (
						<li>{tag}</li>
					))}
				</ul>
			)}
		</SidebarCard>
	</Fragment>

	<Fragment slot="right-rail">
		<SidebarCard title="Related Relics" eyebrow="Internal Links">
			{relatedPosts.length > 0 ? (
				<ul>
					{relatedPosts.map((entry) => (
						<li>
							<a href={`/blog/${entry.id}/`}>{entry.data.title}</a>
						</li>
					))}
				</ul>
			) : (
				<p>The archive is still small, so this page is currently a terminal artifact.</p>
			)}
		</SidebarCard>
	</Fragment>

	<article class="article-shell">
		<header class="article-header">
			<p class="eyebrow">{section}</p>
			<h1>{title}</h1>
			<p class="article-description">{description}</p>
			<div class="meta-row">
				<FormattedDate date={pubDate} />
				{updatedDate && (
					<>
						<span aria-hidden="true">/</span>
						<span>Updated <FormattedDate date={updatedDate} /></span>
					</>
				)}
			</div>
			{tags.length > 0 && (
				<ul class="tag-row" aria-label="Article topics">
					{tags.map((tag) => (
						<li>{tag}</li>
					))}
				</ul>
			)}
		</header>

		{heroImage && (
			<div class="article-hero">
				<img src={heroImage} alt="" width={1280} height={720} />
			</div>
		)}

		<div class="article-prose prose">
			<slot />
		</div>

		{relatedPosts.length > 0 && (
			<section class="section-block">
				<div class="section-head">
					<div>
						<p class="eyebrow">Next Relics</p>
						<h3>Continue the excavation</h3>
					</div>
				</div>
				<div class="link-grid">
					{relatedPosts.map((entry) => (
						<a class="micro-card" href={`/blog/${entry.id}/`}>
							<p class="section-kicker">{entry.data.section}</p>
							<h4>{entry.data.title}</h4>
							<p>{entry.data.description}</p>
						</a>
					))}
				</div>
			</section>
		)}
	</article>
</ClassicShell>
