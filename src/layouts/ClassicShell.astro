---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SidebarCard from '../components/SidebarCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';
import { getTagCounts, sortPosts } from '../lib/content';
import { TOPIC_ORDER, getTopic } from '../data/taxonomy';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	pageTitle?: string;
	pageIntro?: string;
	introLabel?: string;
	showPageIntro?: boolean;
	schema?: Record<string, unknown> | Record<string, unknown>[];
	ogType?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image,
	pageTitle = SITE_TITLE,
	pageIntro = SITE_DESCRIPTION,
	introLabel = 'Overview',
	showPageIntro = true,
	schema,
	ogType = 'website',
	publishedTime,
	modifiedTime,
} = Astro.props;

const pageURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).toString();
const defaultSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: title,
	url: pageURL,
	description,
	isPartOf: {
		'@type': 'WebSite',
		name: SITE_TITLE,
		url: SITE_URL,
	},
};

const schemaPayload = schema
	? [
			{
				'@context': 'https://schema.org',
				'@type': 'WebSite',
				name: SITE_TITLE,
				url: SITE_URL,
				description: SITE_DESCRIPTION,
			},
			...(Array.isArray(schema) ? schema : [schema]),
		]
	: [
			{
				'@context': 'https://schema.org',
				'@type': 'WebSite',
				name: SITE_TITLE,
				url: SITE_URL,
				description: SITE_DESCRIPTION,
			},
			defaultSchema,
		];

const posts = sortPosts(await getCollection('blog'));
const latestPosts = posts.slice(0, 4);
const popularTags = getTagCounts(posts).slice(0, 10);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			ogType={ogType}
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
			schema={schemaPayload}
		/>
	</head>
	<body>
		<div class="site-frame">
			<Header />

			<div class="layout-shell">
				<main class="content-column">
					<div class="content-stack">
						{
							showPageIntro && (
								<section class="page-intro">
									<p class="eyebrow">{introLabel}</p>
									<h2>{pageTitle}</h2>
									<p>{pageIntro}</p>
								</section>
							)
						}

						<slot />
					</div>
				</main>

				<aside class="sidebar-column">
					<div class="sidebar-stack">
						<slot name="sidebar-top" />

						<SidebarCard title="Browse by Topic" eyebrow="Shelf Index">
							<ul>
								{TOPIC_ORDER.map((topicKey) => {
									const topic = getTopic(topicKey);
									return (
										<li>
											<a href={`/topics/${topic.slug}/`}>{topic.name}</a>
										</li>
									);
								})}
							</ul>
						</SidebarCard>

						{popularTags.length > 0 && (
							<SidebarCard title="Popular Tags" eyebrow="Keywords">
								<ul>
									{popularTags.slice(0, 6).map((tag) => (
										<li>
											<a href={`/tags/${tag.slug}/`}>{tag.tag}</a>
										</li>
									))}
								</ul>
							</SidebarCard>
						)}

						<SidebarCard title="Latest Posts" eyebrow="Archive Feed">
							<ul>
								{latestPosts.map((post) => (
									<li>
										<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									</li>
								))}
							</ul>
						</SidebarCard>

						<slot name="sidebar-bottom" />
					</div>
				</aside>
			</div>

			<Footer />
		</div>
	</body>
</html>
