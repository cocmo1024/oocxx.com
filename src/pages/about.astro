---
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_TITLE } from '../consts';
import { ORGANIZATION_SCHEMA_ID } from '../lib/seo';

const principles = [
	{
		title: 'Narrow focus beats generic advice',
		text: 'The site focuses on personal websites, independent blogging, and small-site growth so each article can go deeper than broad marketing content.',
	},
	{
		title: 'Practical before performative',
		text: 'The goal is not to sound smart about publishing. The goal is to help a reader build a better website, page, or discovery system today.',
	},
	{
		title: 'Strong structure compounds',
		text: 'Topics, tags, internal links, and article clusters are treated as product decisions because they determine whether a site grows.',
	},
];
---

<ClassicShell
	title={`${SITE_TITLE} | About`}
	description="About OOCXX: what it covers, how it is organized, and why personal websites deserve better advice."
	pageTitle="About OOCXX"
	pageIntro="OOCXX is an independent editorial site about personal websites, blogging systems, homepage copy, information architecture, and sustainable organic growth."
	introLabel="About"
	schemaType="AboutPage"
	breadcrumbItems={[
		{ name: 'Home', item: '/' },
		{ name: 'About' },
	]}
	about={{ '@id': ORGANIZATION_SCHEMA_ID }}
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="Coverage" eyebrow="What This Site Covers">
			<ul>
				<li>Starting and structuring a personal website</li>
				<li>Homepage, about page, and navigation decisions</li>
				<li>Blogging systems, categories, tags, and archives</li>
				<li>Internal linking, evergreen content, and SEO fundamentals</li>
			</ul>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Why This Exists</p>
				<h3>Personal websites deserve better advice</h3>
			</div>
		</div>
		<p>
			Most content about websites is aimed at startups, agencies, or social-first creators. That leaves
			a gap for people building quieter, smaller, independent sites: personal websites, solo blogs,
			portfolio sites with writing, and compact editorial projects.
		</p>
		<p>
			OOCXX exists to close that gap. It treats the personal website as a serious publishing object and
			covers the page systems, writing decisions, and discovery mechanics that make a small site useful
			and discoverable.
		</p>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Editorial Principles</p>
				<h3>How the site is written</h3>
			</div>
		</div>
		<div class="note-grid">
			{principles.map((item) => (
				<div class="note-card">
					<p class="section-kicker">Principle</p>
					<h4>{item.title}</h4>
					<p>{item.text}</p>
				</div>
			))}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Reading Path</p>
				<h3>Three good places to start</h3>
			</div>
		</div>
		<ul>
			<li><a href="/blog/how-to-start-a-personal-website/">How to start a personal website</a> if you are building from zero.</li>
			<li><a href="/blog/personal-website-launch-checklist/">Launch checklist</a> if the site is almost ready to publish.</li>
			<li><a href="/blog/personal-website-homepage-checklist/">Homepage checklist</a> if your front page is weak.</li>
			<li><a href="/blog/how-to-get-a-personal-website-on-google/">Google discovery guide</a> if the site is live but hard to find.</li>
			<li><a href="/blog/personal-website-seo-checklist/">SEO checklist</a> if the site exists but organic discovery is flat.</li>
		</ul>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Editorial Standard</p>
				<h3>How new pages are judged</h3>
			</div>
		</div>
		<p>
			Every new guide should answer a real reader decision, align its title and description with the
			visible page, and connect naturally to the site structure. The full standard is documented in the
			<a href="/editorial-policy/">editorial policy</a>.
		</p>
	</section>
</ClassicShell>
