---
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_TITLE } from '../consts';

const principles = [
	{
		title: 'Useful before nostalgic',
		text: 'The archive is designed to explain old web objects clearly before it celebrates their visual charm.',
	},
	{
		title: 'Small subjects, complete pages',
		text: 'Each article focuses on one object, behavior, or page convention so readers can find an exact answer quickly.',
	},
	{
		title: 'Comfortable reading matters',
		text: 'The site borrows the mood of the early web, but the pacing, spacing, and typography are intentionally modern.',
	},
];
---

<ClassicShell
	title={`${SITE_TITLE} | About`}
	description="About the OOCXX Classic Web Archive: what it covers, how it is organized, and why early personal websites still matter."
	pageTitle="About the archive"
	pageIntro="OOCXX is a curated blog about the first age of the web: personal homepages, hand-built navigation, public counters, guestbooks, and the visual habits that made small websites feel alive."
	introLabel="About"
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="Archive Scope" eyebrow="Coverage">
			<ul>
				<li>Personal homepages and portal pages</li>
				<li>WebRings, directory links, and old navigation systems</li>
				<li>Guestbooks, counters, and early social traces</li>
				<li>Construction banners, blinking text, and animated web graphics</li>
			</ul>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Why This Exists</p>
				<h3>The early web deserves careful documentation</h3>
			</div>
		</div>
		<p>
			The first era of the web produced a huge number of small, personal, hand-built sites. Many of
			their design habits are now treated as jokes, but they solved real problems: how to be found,
			how to show that a site was alive, how to welcome a visitor, and how to leave a trace.
		</p>
		<p>
			This archive treats those habits as cultural objects. It explains them clearly, places them in
			context, and links them to neighboring ideas so readers can browse the early web as a system
			rather than as a pile of nostalgia.
		</p>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Editorial Principles</p>
				<h3>How the archive is written</h3>
			</div>
		</div>
		<div class="note-grid">
			{principles.map((item) => (
				<div class="note-card">
					<p class="section-kicker">Principle</p>
					<h4>{item.title}</h4>
					<p>{item.text}</p>
				</div>
			))}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Reading Path</p>
				<h3>Three good places to start</h3>
			</div>
		</div>
		<ul>
			<li><a href="/blog/webring-explainer/">WebRings</a> if you want to understand old discovery systems.</li>
			<li><a href="/blog/guestbook-history/">Guestbooks</a> if you are curious about early social traces.</li>
			<li><a href="/blog/geocities-homepage-layout/">GeoCities-style homepages</a> if you care most about layout and atmosphere.</li>
		</ul>
	</section>
</ClassicShell>
