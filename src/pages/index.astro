---
import { getCollection } from 'astro:content';
import PostPreviewCard from '../components/PostPreviewCard.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';
import { TOPIC_ORDER, getTopic } from '../data/taxonomy';
import { getFeaturedPost, getTagCounts, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('blog'));
const featuredPost = getFeaturedPost(posts);
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 4);
const topicCards = TOPIC_ORDER.map((key) => ({
	...getTopic(key),
	entries: posts.filter((post) => post.data.topic === key).slice(0, 2),
}));
const popularTags = getTagCounts(posts).slice(0, 12);

const homeSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: `${SITE_TITLE} Home`,
	url: SITE_URL,
	description: SITE_DESCRIPTION,
};
---

<ClassicShell
	title={`${SITE_TITLE} | Early Web Field Notes`}
	description="A curated archive of essays about WebRings, guestbooks, counters, homepage design, retro web graphics, and early internet habits."
	pageTitle="An archive of how the early web looked, linked, and felt"
	pageIntro="OOCXX is a long-form blog about the first age of the web: personal homepages, hand-built navigation, loud graphics, guestbooks, counters, and the design habits that made small sites feel personal."
	introLabel="Welcome"
	schema={homeSchema}
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="Start Here" eyebrow="Reader Guide">
			<ul>
				<li><a href="/blog/webring-explainer/">What a WebRing was</a></li>
				<li><a href="/blog/guestbook-history/">Why guestbooks mattered</a></li>
				<li><a href="/topics">Browse the archive by topic</a></li>
			</ul>
		</SidebarCard>
	</Fragment>

	<Fragment slot="sidebar-bottom">
		<SidebarCard title="Archive Format" eyebrow="What You’ll Find">
			<p>
				Each article takes one object, habit, or visual trope from the classic web and explains what
				it was, why it mattered, and how it shaped online culture.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="hero-banner">
		<div>
			<p class="eyebrow">Small Sites / 1994 to 2004</p>
			<h2>The classic web was messy, personal, hand-linked, and strangely elegant.</h2>
			<p>
				This archive documents the tools and habits that made early websites feel like rooms with
				owners: WebRings, counters, guestbooks, splash pages, construction GIFs, and homepage layouts.
			</p>
		</div>
		<div class="hero-banner-side">
			<div class="marquee-bar" aria-label="Archive strip">
				<span>WebRings / Guestbooks / Counters / GeoCities / Construction GIFs / Marquees / Splash Pages / MIDI / Portal Pages</span>
			</div>
		</div>
	</section>

	{featuredPost && (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Featured Story</p>
					<h3>Start with the archive entry that defines the site</h3>
				</div>
			</div>
			<PostPreviewCard post={featuredPost} featured={true} />
		</section>
	)}

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Browse by Topic</p>
				<h3>Four shelves for the first era of the archive</h3>
			</div>
		</div>

		<div class="topic-grid">
			{topicCards.map((topic) => (
				<a class="topic-card" href={`/topics/${topic.slug}/`}>
					<p class="section-kicker">Topic</p>
					<h4>{topic.name}</h4>
					<p>{topic.shortDescription}</p>
					{topic.entries.length > 0 && (
						<ul>
							{topic.entries.map((entry) => (
								<li>{entry.data.title}</li>
							))}
						</ul>
					)}
				</a>
			))}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Latest Posts</p>
				<h3>Recently added field notes</h3>
			</div>
		</div>

		<div class="post-stream">
			{latestPosts.map((post) => <PostPreviewCard post={post} />)}
		</div>
	</section>

	{popularTags.length > 0 && (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Tag Index</p>
					<h3>Popular keywords across the archive</h3>
				</div>
			</div>
			<ul class="tag-cloud" aria-label="Popular tags">
				{popularTags.map((tag) => (
					<li>
						<a href={`/tags/${tag.slug}/`}>{tag.tag}</a>
					</li>
				))}
			</ul>
		</section>
	)}
</ClassicShell>
