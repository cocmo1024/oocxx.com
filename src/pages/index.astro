---
import { getCollection } from 'astro:content';
import PostPreviewCard from '../components/PostPreviewCard.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';
import { TOPIC_ORDER, getTopic } from '../data/taxonomy';
import { getFeaturedPost, getTagCounts, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('blog'));
const featuredPost = getFeaturedPost(posts);
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 4);
const topicCards = TOPIC_ORDER.map((key) => ({
	...getTopic(key),
	entries: posts.filter((post) => post.data.topic === key).slice(0, 2),
}));
const popularTags = getTagCounts(posts).slice(0, 12);

const homeSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: `${SITE_TITLE} Home`,
	url: SITE_URL,
	description: SITE_DESCRIPTION,
};
---

<ClassicShell
	title={`${SITE_TITLE} | Personal Website Playbook`}
	description="Practical guides for planning, writing, structuring, and growing a personal website or independent blog."
	pageTitle="Build a personal website people can actually find and read"
	pageIntro="OOCXX is an editorial site about personal websites, blogging systems, homepage copy, information architecture, and sustainable search traffic for small independent sites."
	introLabel="Start Here"
	schema={homeSchema}
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="Read First" eyebrow="Core Guides">
			<ul>
				<li><a href="/blog/how-to-start-a-personal-website/">How to start a personal website</a></li>
				<li><a href="/blog/personal-website-homepage-checklist/">What to put on your homepage</a></li>
				<li><a href="/blog/personal-website-seo-checklist/">Personal website SEO checklist</a></li>
			</ul>
		</SidebarCard>
	</Fragment>

	<Fragment slot="sidebar-bottom">
		<SidebarCard title="Editorial Focus" eyebrow="What You'll Find">
			<p>
				The site focuses on evergreen questions around personal websites, publishing systems, site
				structure, and search-friendly growth rather than broad marketing chatter.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="hero-banner">
		<div>
			<p class="eyebrow">Personal Websites / Blogging / Small Sites</p>
			<h2>Build a small website with clear pages, useful writing, and durable traffic.</h2>
			<p>
				Most advice for websites is either too broad, too corporate, or too obsessed with short-term
				platform tricks. This site is about building a personal website that is readable, searchable,
				and structured to compound.
			</p>
		</div>
		<div class="hero-banner-side">
			<div class="marquee-bar" aria-label="Topic strip">
				<span>Homepages / About Pages / Navigation / Categories / Tags / Internal Linking / Evergreen Content / SEO / Personal Brand</span>
			</div>
		</div>
	</section>

	{featuredPost && (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Featured Guide</p>
					<h3>Start with the guide that defines the site</h3>
				</div>
			</div>
			<PostPreviewCard post={featuredPost} featured={true} />
		</section>
	)}

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Browse by Topic</p>
				<h3>Four systems behind a strong personal website</h3>
			</div>
		</div>

		<div class="topic-grid">
			{topicCards.map((topic) => (
				<a class="topic-card" href={`/topics/${topic.slug}/`}>
					<p class="section-kicker">Topic</p>
					<h4>{topic.name}</h4>
					<p>{topic.shortDescription}</p>
					{topic.entries.length > 0 && (
						<ul>
							{topic.entries.map((entry) => (
								<li>{entry.data.title}</li>
							))}
						</ul>
					)}
				</a>
			))}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Latest Guides</p>
				<h3>Recently published and updated</h3>
			</div>
		</div>

		<div class="post-stream">
			{latestPosts.map((post) => <PostPreviewCard post={post} />)}
		</div>
	</section>

	{popularTags.length > 0 && (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Tag Index</p>
					<h3>Popular topics across the site</h3>
				</div>
			</div>
			<ul class="tag-cloud" aria-label="Popular tags">
				{popularTags.map((tag) => (
					<li>
						<a href={`/tags/${tag.slug}/`}>{tag.tag}</a>
					</li>
				))}
			</ul>
		</section>
	)}
</ClassicShell>
