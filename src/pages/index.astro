---
import { getCollection } from 'astro:content';
import PostPreviewCard from '../components/PostPreviewCard.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_TITLE, SITE_URL } from '../consts';
import { TOPIC_ORDER, getTopic } from '../data/taxonomy';
import { getFeaturedPost, getTagCounts, sortPosts } from '../lib/content';
import { getItemListSchema } from '../lib/seo';

const posts = sortPosts(await getCollection('blog'));
const featuredPost = getFeaturedPost(posts);
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 4);
const topicCards = TOPIC_ORDER.map((key) => ({
	...getTopic(key),
	entries: posts.filter((post) => post.data.topic === key).slice(0, 2),
}));
const popularTags = getTagCounts(posts).slice(0, 12);
const featuredEntries = [featuredPost, ...latestPosts].filter(
	(post, index, list): post is NonNullable<typeof post> =>
		Boolean(post) && list.findIndex((entry) => entry?.id === post?.id) === index,
);
const featuredItemListId = `${SITE_URL}/#featured-guides`;
const homeSchema = getItemListSchema(
	featuredItemListId,
	featuredEntries.map((post) => ({
		name: post.data.title,
		url: `/blog/${post.id}/`,
	})),
);
---

<ClassicShell
	title={`${SITE_TITLE} | Personal Website Playbook`}
	description="Practical guides for planning, writing, structuring, and growing a personal website or independent blog."
	pageTitle="Build a personal website people can actually find and read"
	pageIntro="OOCXX is an editorial site about personal websites, blogging systems, homepage copy, information architecture, and sustainable organic growth for small independent sites."
	introLabel="Start Here"
	schemaType="CollectionPage"
	mainEntityId={featuredItemListId}
	schema={homeSchema}
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="Read First" eyebrow="Core Guides">
			<ul>
				<li><a href="/blog/how-to-start-a-personal-website/">How to start a personal website</a></li>
				<li><a href="/blog/personal-website-launch-checklist/">Personal website launch checklist</a></li>
				<li><a href="/blog/what-pages-should-a-personal-website-have/">What pages should a personal website have?</a></li>
				<li><a href="/blog/personal-website-seo-checklist/">Personal website SEO checklist</a></li>
			</ul>
		</SidebarCard>
	</Fragment>

	<Fragment slot="sidebar-bottom">
		<SidebarCard title="Naming & Domains" eyebrow="Decision Guides">
			<ul>
				<li><a href="/blog/how-to-choose-a-domain-name-for-a-personal-website/">How to choose a domain name</a></li>
				<li><a href="/blog/should-you-use-your-own-name-as-a-domain/">Should you use your own name as a domain?</a></li>
				<li><a href="/blog/personal-website-name-ideas/">Personal website name ideas</a></li>
				<li><a href="/blog/blog-name-ideas-for-beginners-and-personal-sites/">Blog name ideas for beginners</a></li>
			</ul>
		</SidebarCard>
	</Fragment>

	<section class="hero-banner">
		<div>
			<p class="eyebrow">Personal Websites / Blogging / Small Sites</p>
			<h2>Build a small website with clear pages, useful writing, and durable discovery.</h2>
			<p>
				Most advice for websites is either too broad, too corporate, or too obsessed with short-term
				platform tricks. This site is about building a personal website that is readable, searchable,
				and structured to compound.
			</p>
		</div>
		<div class="hero-banner-side">
			<div class="marquee-bar" aria-label="Topic strip">
				<span>Domains / Naming / Homepages / Headlines / Taglines / About Pages / Contact Pages / Footers / Navigation / Categories / Tags / SEO</span>
			</div>
		</div>
	</section>

	{featuredPost && (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Featured Guide</p>
					<h3>Start with the guide that defines the site</h3>
				</div>
			</div>
			<PostPreviewCard post={featuredPost} featured={true} />
		</section>
	)}

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">High-Utility Path</p>
				<h3>Plan, launch, audit, then expand</h3>
			</div>
		</div>
		<div class="link-grid">
			<a class="micro-card" href="/blog/personal-website-launch-checklist/">
				<p class="section-kicker">Launch</p>
				<h4>Personal website launch checklist</h4>
				<p>Check the first version before publishing: pages, navigation, metadata, links, and mobile readability.</p>
			</a>
			<a class="micro-card" href="/blog/personal-website-audit-checklist/">
				<p class="section-kicker">Audit</p>
				<h4>Personal website audit checklist</h4>
				<p>Review an existing site before adding more pages or chasing advanced optimization.</p>
			</a>
			<a class="micro-card" href="/blog/personal-website-content-strategy/">
				<p class="section-kicker">Strategy</p>
				<h4>Personal website content strategy</h4>
				<p>Turn the site into a coherent body of work instead of a random archive.</p>
			</a>
			<a class="micro-card" href="/blog/personal-website-mistakes/">
				<p class="section-kicker">Fixes</p>
				<h4>Personal website mistakes</h4>
				<p>Find the structural problems that make a personal site harder to understand and trust.</p>
			</a>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Browse by Topic</p>
				<h3>Four systems behind a strong personal website</h3>
			</div>
		</div>

		<div class="topic-grid">
			{topicCards.map((topic) => (
				<a class="topic-card" href={`/topics/${topic.slug}/`}>
					<p class="section-kicker">Topic</p>
					<h4>{topic.name}</h4>
					<p>{topic.shortDescription}</p>
					{topic.entries.length > 0 && (
						<ul>
							{topic.entries.map((entry) => (
								<li>{entry.data.title}</li>
							))}
						</ul>
					)}
				</a>
			))}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Latest Guides</p>
				<h3>Recently published and updated</h3>
			</div>
		</div>

		<div class="post-stream">
			{latestPosts.map((post) => <PostPreviewCard post={post} />)}
		</div>
	</section>

	{popularTags.length > 0 && (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Tag Index</p>
					<h3>Popular topics across the site</h3>
				</div>
			</div>
			<ul class="tag-cloud" aria-label="Popular tags">
				{popularTags.map((tag) => (
					<li>
						<a href={`/tags/${tag.slug}/`}>{tag.tag}</a>
					</li>
				))}
			</ul>
		</section>
	)}
</ClassicShell>
