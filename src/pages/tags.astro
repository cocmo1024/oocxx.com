---
import { getCollection } from 'astro:content';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_TITLE, SITE_URL } from '../consts';
import { getTagCounts, sortPosts } from '../lib/content';
import { getItemListSchema } from '../lib/seo';

const posts = sortPosts(await getCollection('blog'));
const tags = getTagCounts(posts);
const tagItemListId = `${SITE_URL}/tags/#tag-index`;
const tagItemList = getItemListSchema(
	tagItemListId,
	tags.map((tag) => ({
		name: tag.tag,
		url: `/tags/${tag.slug}/`,
	})),
);
---

<ClassicShell
	title={`${SITE_TITLE} | Tags`}
	description="Browse OOCXX by tag, including homepage, about page, SEO, categories, tags, internal linking, and other personal website topics."
	pageTitle="Browse the site by tag"
	pageIntro="Tags connect guides that share a narrower concept across the broader topic structure, making the site easier to scan by problem instead of by section alone."
	introLabel="Tags"
	schemaType="CollectionPage"
	breadcrumbItems={[
		{ name: 'Home', item: '/' },
		{ name: 'Tags' },
	]}
	mainEntityId={tagItemListId}
	schema={tagItemList}
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="How Tags Work" eyebrow="Navigation">
			<p>
				Topics organize the site broadly. Tags cross-link narrower ideas such as homepage copy,
				internal linking, categories, about pages, navigation, or search traffic.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Tag Cloud</p>
				<h3>Every keyword currently used on the site</h3>
			</div>
		</div>
		<ul class="tag-cloud" aria-label="All tags">
			{tags.map((tag) => (
				<li>
					<a href={`/tags/${tag.slug}/`}>{tag.tag}</a>
					<span class="tag-count">{tag.count}</span>
				</li>
			))}
		</ul>
	</section>
</ClassicShell>
