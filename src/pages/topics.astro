---
import { getCollection } from 'astro:content';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_TITLE } from '../consts';
import { TOPIC_ORDER, getTopic } from '../data/taxonomy';
import { getPostsByTopic, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('blog'));
---

<ClassicShell
	title={`${SITE_TITLE} | Topics`}
	description="Browse OOCXX by topic: foundations, page structure, publishing systems, and search-friendly growth."
	pageTitle="Browse the site by topic"
	pageIntro="The site is organized around four recurring systems: planning the website, building strong pages, publishing coherently, and growing traffic without platform dependence."
	introLabel="Topics"
>
	<Fragment slot="sidebar-top">
		<SidebarCard title="Topic Pages" eyebrow="Browse">
			<ul>
				{TOPIC_ORDER.map((topicKey) => {
					const topic = getTopic(topicKey);
					return (
						<li>
							<a href={`/topics/${topic.slug}/`}>{topic.name}</a>
						</li>
					);
				})}
			</ul>
		</SidebarCard>
	</Fragment>

	<div class="topic-grid">
		{TOPIC_ORDER.map((topicKey) => {
			const topic = getTopic(topicKey);
			const entries = getPostsByTopic(posts, topicKey).slice(0, 3);
			return (
				<a class="topic-card" href={`/topics/${topic.slug}/`}>
					<p class="section-kicker">Topic</p>
					<h3>{topic.name}</h3>
					<p>{topic.description}</p>
					<ul>
						{entries.map((entry) => (
							<li>{entry.data.title}</li>
						))}
					</ul>
				</a>
			);
		})}
	</div>
</ClassicShell>
