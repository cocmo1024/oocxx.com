---
import { getCollection } from 'astro:content';
import PostPreviewCard from '../../components/PostPreviewCard.astro';
import SidebarCard from '../../components/SidebarCard.astro';
import ClassicShell from '../../layouts/ClassicShell.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const sectionCounts = Array.from(
	posts.reduce((map, post) => {
		map.set(post.data.section, (map.get(post.data.section) ?? 0) + 1);
		return map;
	}, new Map<string, number>()),
);
---

<ClassicShell
	title={`${SITE_TITLE} | Archive`}
	description="Full archive of OOCXX field notes on web rings, guestbooks, counters, GeoCities layouts, and other early internet artifacts."
	pageTitle="Archive and field-note stream"
	pageIntro="This is the full excavation log. Every entry targets one classic internet object, phrase, or habit and links back into a broader topic cluster."
	introLabel="Archive"
>
	<Fragment slot="left-rail">
		<SidebarCard title="Archive Shape" eyebrow="Sections">
			<ul>
				{sectionCounts.map(([section, count]) => (
					<li>{section}: {count}</li>
				))}
			</ul>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Reading Order</p>
				<h3>Latest field notes first</h3>
			</div>
		</div>

		<div class="post-stream">
			{posts.length === 0 ? (
				<p>No field notes have been filed yet.</p>
			) : (
				posts.map((post, index) => <PostPreviewCard post={post} featured={index === 0} />)
			)}
		</div>
	</section>
</ClassicShell>
